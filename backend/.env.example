# Server port (default :8080)
PORT=:8080
# SQLite database path
DB_PATH=pulso.db
# Allowed CORS origin (default http://localhost:4321)
CORS_ORIGIN=http://localhost:4321

# JWT signing key (required — server crashes if empty)
JWT_SECRET=jwt-secret
# Secret code that grants health_worker role on signup (required — server crashes if empty)
HEALTH_WORKER_SECRET=hw-secret

# Gemini 3.1 Flash Lite API key (optional — AI returns 503 without it)
GEMINI_API_KEY=
