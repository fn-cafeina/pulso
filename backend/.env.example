# Server port (default :8080)
PORT=:8080

# SQLite database path
DB_PATH=pulso.db

# Allowed CORS origin (default http://localhost:5173)
CORS_ORIGIN=http://localhost:5173

# JWT signing key (required — server crashes if empty)
JWT_SECRET=jwt-secret

# Secret code that grants health_worker role on signup (required — server crashes if empty)
HEALTH_WORKER_SECRET=hw-secret

# NVIDIA NIM API key (optional — AI returns error without it)
NVIDIA_API_KEY=

# NVIDIA NIM model (default: mistralai/mistral-large-3-675b-instruct-2512)
NVIDIA_MODEL=mistralai/mistral-large-3-675b-instruct-2512
