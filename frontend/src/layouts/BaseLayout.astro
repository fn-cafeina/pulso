---
import '../styles/global.css'
import { ClientRouter } from 'astro:transitions';
const { pageTitle } = Astro.props;
---
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="theme-color" content="#004a99" />
    <meta name="description" content="Pulso — Asistente virtual de salud para familias nicaragüenses" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
    <ClientRouter />
  </head>
  <body class="bg-neutral">
    <noscript>
      <div class="min-h-screen flex items-center justify-center p-4">
        <div class="bg-white rounded-xl shadow-lg p-8 max-w-md text-center">
          <h1 class="text-2xl font-bold text-primary mb-2">Pulso</h1>
          <p class="text-gray">JavaScript es requerido para usar esta aplicación. Por favor, habilita JavaScript en tu navegador.</p>
        </div>
      </div>
    </noscript>
    <slot />
  </body>
</html>
