---
import '../styles/global.css'
import { ClientRouter } from 'astro:transitions';
import AuthGuard from '../components/layout/AuthGuard';
import SidebarNav from '../components/layout/SidebarNav';
import BottomNav from '../components/layout/BottomNav';
import MobileDrawer from '../components/layout/MobileDrawer';

const { pageTitle, currentPath } = Astro.props;
---
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="theme-color" content="#004a99" />
    <meta name="description" content="Pulso — Asistente virtual de salud para familias nicaragüenses" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
    <ClientRouter />
  </head>
  <body class="bg-neutral">
    <noscript>
      <div class="min-h-screen flex items-center justify-center p-4">
        <div class="bg-white rounded-xl shadow-lg p-8 max-w-md text-center">
          <h1 class="text-2xl font-bold text-primary mb-2">Pulso</h1>
          <p class="text-gray">JavaScript es requerido para usar esta aplicación. Por favor, habilita JavaScript en tu navegador.</p>
        </div>
      </div>
    </noscript>

    <AuthGuard client:load />

    <aside class="hidden md:flex md:w-64 md:flex-col md:fixed md:inset-y-0 bg-white border-r border-gray/20 z-40">
      <SidebarNav currentPath={currentPath} client:idle />
    </aside>

    <div class="md:ml-64 h-screen flex flex-col">
      <header class="bg-white border-b border-gray/20 px-4 py-3 pt-[calc(0.75rem+env(safe-area-inset-top))] flex items-center justify-between md:hidden z-30">
        <MobileDrawer currentPath={currentPath} client:idle />
      </header>

      <main class="flex-1 overflow-y-auto">
        <slot />
      </main>

      <nav class="bg-white border-t border-gray/20 z-20 pb-[env(safe-area-inset-bottom)] md:hidden" aria-label="Navegación principal">
        <BottomNav currentPath={currentPath} client:idle />
      </nav>
    </div>
  </body>
</html>
