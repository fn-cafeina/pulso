---
import '../styles/global.css'
import AuthGuard from '../components/layout/AuthGuard';
import Nav from '../components/layout/Nav';

const { pageTitle, currentPath } = Astro.props;
---
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="theme-color" content="#004a99" />
    <meta name="description" content="Pulso — Asistente virtual de salud para familias nicaragüenses" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
  </head>
  <body class="bg-neutral">
    <noscript>
      <div class="min-h-screen flex items-center justify-center p-4">
        <div class="bg-white rounded-xl shadow-lg p-8 max-w-md text-center">
          <h1 class="text-2xl font-bold text-primary mb-2">Pulso</h1>
          <p class="text-gray">JavaScript es requerido para usar esta aplicación. Por favor, habilita JavaScript en tu navegador.</p>
        </div>
      </div>
    </noscript>

    <AuthGuard client:load />

    <div class="flex min-h-screen">
      <aside class="hidden md:flex md:w-64 md:flex-col md:fixed md:inset-y-0 bg-white border-r border-gray/20">
        <Nav currentPath={currentPath} client:load />
      </aside>

      <div class="flex-1 md:ml-64">
        <header class="bg-white border-b border-gray/20 px-4 py-3 flex items-center justify-between md:hidden">
          <Nav currentPath={currentPath} client:load mobileHeader />
        </header>

        <main class="p-4 pb-20 md:p-8 md:pb-8">
          <slot />
        </main>
      </div>

      <nav class="md:hidden fixed bottom-0 inset-x-0 bg-white border-t border-gray/20 z-50 pb-[env(safe-area-inset-bottom)]" aria-label="Navegación principal">
        <Nav currentPath={currentPath} client:load bottomNav />
      </nav>
    </div>
  </body>
</html>
