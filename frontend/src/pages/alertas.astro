---
import AppLayout from '../layouts/AppLayout.astro';
import { AlertTriangle } from 'lucide-react';
---

<AppLayout pageTitle="Alertas — Pulso" currentPath="/alertas">
  <div class="py-4 md:py-6 px-4 md:px-8 flex flex-col items-center justify-center min-h-[60vh] text-center animate-fade-in-up">
    <div class="inline-flex items-center justify-center w-20 h-20 bg-primary/10 text-primary rounded-xl mb-6 animate-float">
      <AlertTriangle size={40} />
    </div>
    <h2 class="text-2xl font-bold text-text mb-2">Alertas Epidemiológicas</h2>
    <p class="text-gray max-w-md">Mantente informado sobre alertas de salud en tu zona.</p>
    <div class="mt-6 px-4 py-2 bg-info/10 text-info rounded-button text-sm font-medium">
      Próximamente
    </div>
  </div>
</AppLayout>
