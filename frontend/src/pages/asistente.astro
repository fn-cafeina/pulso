---
import AppLayout from '../layouts/AppLayout.astro';
import { Stethoscope } from 'lucide-react';
---

<AppLayout pageTitle="Asistente IA — Pulso" currentPath="/asistente">
  <div class="flex flex-col items-center justify-center min-h-[60vh] text-center">
    <div class="inline-flex items-center justify-center w-20 h-20 bg-primary/10 rounded-2xl mb-6">
      <Stethoscope class="w-10 h-10 text-primary" />
    </div>
    <h2 class="text-2xl font-bold text-text mb-2">Asistente de Salud</h2>
    <p class="text-gray max-w-md">Consulta al asistente virtual sobre signos, síntomas y orientación de salud.</p>
    <div class="mt-6 px-4 py-2 bg-info/10 text-info rounded-lg text-sm font-medium">
      Próximamente
    </div>
  </div>
</AppLayout>
