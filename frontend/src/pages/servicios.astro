---
import AppLayout from '../layouts/AppLayout.astro';
import { MapPin } from 'lucide-react';
---

<AppLayout pageTitle="Servicios Cercanos — Pulso" currentPath="/servicios">
  <div class="py-4 md:py-6 px-4 md:px-8 flex flex-col items-center justify-center min-h-[60vh] text-center">
    <div class="inline-flex items-center justify-center w-20 h-20 bg-primary/10 rounded-xl mb-6">
      <MapPin class="w-10 h-10 text-primary" />
    </div>
    <h2 class="text-2xl font-bold text-text mb-2">Servicios Cercanos</h2>
    <p class="text-gray max-w-md">Encuentra centros de salud, clínicas y puestos de salud cerca de ti.</p>
    <div class="mt-6 px-4 py-2 bg-info/10 text-info rounded-lg text-sm font-medium">
      Próximamente
    </div>
  </div>
</AppLayout>
