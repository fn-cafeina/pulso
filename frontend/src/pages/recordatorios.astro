---
import AppLayout from '../layouts/AppLayout.astro';
import { Bell } from 'lucide-react';
---

<AppLayout pageTitle="Recordatorios — Pulso" currentPath="/recordatorios">
  <div class="py-4 md:py-6 px-4 md:px-8 flex flex-col items-center justify-center min-h-[60vh] text-center animate-fade-in-up">
    <div class="inline-flex items-center justify-center w-20 h-20 bg-primary/10 rounded-xl mb-6">
      <Bell class="w-10 h-10 text-primary" />
    </div>
    <h2 class="text-2xl font-bold text-text mb-2">Recordatorios</h2>
    <p class="text-gray max-w-md">Citas médicas, vacunas y recordatorios pendientes.</p>
    <div class="mt-6 px-4 py-2 bg-info/10 text-info rounded-button text-sm font-medium">
      Próximamente
    </div>
  </div>
</AppLayout>
