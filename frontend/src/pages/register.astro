---
import BaseLayout from '../layouts/BaseLayout.astro';
import RegisterForm from '../components/auth/RegisterForm';
---

<BaseLayout pageTitle="Crear Cuenta — Pulso">
  <main class="min-h-screen bg-neutral flex items-center justify-center px-4 py-8">
    <div class="w-full max-w-md">
      <div class="text-center mb-8">
        <h1 class="text-3xl font-bold text-primary">Pulso</h1>
        <p class="text-gray mt-1">Su asistente de monitoreo de salud</p>
      </div>

      <div class="bg-white rounded-xl shadow-md p-6 sm:p-8">
        <h2 class="text-xl font-semibold text-text mb-6">Crear Cuenta</h2>
        <RegisterForm client:load />
      </div>
    </div>
  </main>
</BaseLayout>
